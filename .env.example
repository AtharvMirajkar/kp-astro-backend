# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/kundali_db

# ── Firebase Admin SDK ────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-minimum-32-chars-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_IN=30d

# ── CORS — comma-separated list of allowed admin panel origins ────────────────
ALLOWED_ORIGINS=http://localhost:3001,https://your-admin-panel.com

# ── Email (SMTP / Gmail) ──────────────────────────────────────────────────────
EMAIL_HOST=gmail
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password
EMAIL_FROM_NAME=Kundali App Admin

# ── Admin Panel URL (used in password-reset email links) ──────────────────────
ADMIN_PANEL_URL=http://localhost:3001
