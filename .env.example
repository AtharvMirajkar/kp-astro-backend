# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/kundali_db

# ── Firebase Admin SDK ────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-change-this
JWT_EXPIRES_IN=7d
JWT_REFRESH_IN=30d

# ── Email (SMTP / Gmail) ──────────────────────────────────────────────────────
# For Gmail: set EMAIL_HOST=gmail and use an App Password (not your regular password)
# Generate App Password: Google Account → Security → 2FA → App Passwords
EMAIL_HOST=gmail
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password
EMAIL_FROM_NAME=Kundali App Admin

# ── Admin Panel URL (for password reset links) ────────────────────────────────
ADMIN_PANEL_URL=http://localhost:3001
